00' height='200'></canvas>\\n<script>\\nconst ctx = document.getElementById('c').getContext('2d');\\nctx.fillStyle = 'steelblue';\\nctx.fillRect(50, 50, 100, 100);\\n</script>\"\n\t\t},\n\t\tmeta: null,\n\t\tfull_example: {\n\t\t\tid: \"n13\",\n\t\t\ttype: \"interactive-sandbox\",\n\t\t\tlabel: \"Interactive sine wave\",\n\t\t\tcontent: \"<style>body{font-family:sans-serif;padding:10px;}canvas{border:1px solid #ddd;border-radius:4px;}</style>\\n<canvas id='c' width='400' height='150'></canvas>\\n<script>\\nconst ctx = document.getElementById('c').getContext('2d');\\nctx.beginPath();\\nfor(let x=0;x<400;x++){ctx.lineTo(x, 75 + Math.sin(x/20)*50);}\\nctx.strokeStyle='#3b82f6';\\nctx.lineWidth=2;\\nctx.stroke();\\n</script>\"\n\t\t}\n\t},\n\ttable: {\n\t\tdescription: \"A formatted data table with headers and rows. Optionally includes a caption below.\",\n\t\tcategory: \"scientific_and_technical\",\n\t\tcontent: {\n\t\t\ttype: \"object\",\n\t\t\tdescription: \"Object with 'headers' (column names) and 'rows' (data rows). All values should be strings.\",\n\t\t\tfields: {\n\t\t\t\theaders: {\n\t\t\t\t\ttype: \"string[]\",\n\t\t\t\t\tdescription: \"Column header labels.\"\n\t\t\t\t},\n\t\t\t\trows: {\n\t\t\t\t\ttype: \"string[][]\",\n\t\t\t\t\tdescription: \"2D array of cell values. Each inner array is one row, with values corresponding to columns in 'headers'.\"\n\t\t\t\t}\n\t\t\t},\n\t\t\texample: {\n\t\t\t\theaders: [\n\t\t\t\t\t\"Element\",\n\t\t\t\t\t\"Symbol\",\n\t\t\t\t\t\"Atomic Number\"\n\t\t\t\t],\n\t\t\t\trows: [\n\t\t\t\t\t[\n\t\t\t\t\t\t\"Hydrogen\",\n\t\t\t\t\t\t\"H\",\n\t\t\t\t\t\t\"1\"\n\t\t\t\t\t],\n\t\t\t\t\t[\n\t\t\t\t\t\t\"Carbon\",\n\t\t\t\t\t\t\"C\",\n\t\t\t\t\t\t\"6\"\n\t\t\t\t\t],\n\t\t\t\t\t[\n\t\t\t\t\t\t\"Oxygen\",\n\t\t\t\t\t\t\"O\",\n\t\t\t\t\t\t\"8\"\n\t\t\t\t\t]\n\t\t\t\t]\n\t\t\t}\n\t\t},\n\t\tmeta: {\n\t\t\tcaption: {\n\t\t\t\ttype: \"string\",\n\t\t\t\toptional: true,\n\t\t\t\tdescription: \"Table caption displayed below the table in itali